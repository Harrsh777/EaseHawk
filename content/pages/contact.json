\"rgba(245,244,248,.7)\">UTC+8</text></g><g><circle cx=\"596\" cy=\"401\" r=\"6\" fill=\"none\" stroke=\"#FFDD00\" stroke-width=\"1.4\" opacity=\"0\"><animate attributeName=\"r\" values=\"6;15;19\" keyTimes=\"0;.5;1\" dur=\"1.5s\" begin=\"4.75s;16.75s\" repeatCount=\"indefinite\"/><animate attributeName=\"opacity\" values=\"0;.9;0\" keyTimes=\"0;.3;1\" dur=\"1.5s\" begin=\"4.75s;16.75s\" repeatCount=\"indefinite\"/></circle><circle cx=\"596\" cy=\"401\" r=\"5\" fill=\"#0B0B10\" stroke=\"#FFDD00\" stroke-width=\"1.4\"/><text x=\"611\" y=\"427\" text-anchor=\"start\" font-family=\"Jost\" font-weight=\"600\" font-size=\"11\" letter-spacing=\"1.4\" fill=\"rgba(250,250,253,.95)\">CHICAGO</text><text x=\"611\" y=\"442\" text-anchor=\"start\" font-family=\"Jost\" font-size=\"8.5\" letter-spacing=\"1\" fill=\"rgba(245,244,248,.7)\">UTC−6</text></g><g><circle cx=\"404\" cy=\"401\" r=\"6\" fill=\"none\" stroke=\"#FFDD00\" stroke-width=\"1.4\" opacity=\"0\"><animate attributeName=\"r\" values=\"6;15;19\" keyTimes=\"0;.5;1\" dur=\"1.5s\" begin=\"6.75s;18.75s\" repeatCount=\"indefinite\"/><animate attributeName=\"opacity\" values=\"0;.9;0\" keyTimes=\"0;.3;1\" dur=\"1.5s\" begin=\"6.75s;18.75s\" repeatCount=\"indefinite\"/></circle><circle cx=\"404\" cy=\"401\" r=\"5\" fill=\"#0B0B10\" stroke=\"#FFDD00\" stroke-width=\"1.4\"/><text x=\"389\" y=\"427\" text-anchor=\"end\" font-family=\"Jost\" font-weight=\"600\" font-size=\"11\" letter-spacing=\"1.4\" fill=\"rgba(250,250,253,.95)\">TORONTO</text><text x=\"389\" y=\"442\" text-anchor=\"end\" font-family=\"Jost\" font-size=\"8.5\" letter-spacing=\"1\" fill=\"rgba(245,244,248,.7)\">UTC−5</text></g><g><circle cx=\"404\" cy=\"69\" r=\"6\" fill=\"none\" stroke=\"#FFDD00\" stroke-width=\"1.4\" opacity=\"0\"><animate attributeName=\"r\" values=\"6;15;19\" keyTimes=\"0;.5;1\" dur=\"1.5s\" begin=\"10.75s;22.75s\" repeatCount=\"indefinite\"/><animate attributeName=\"opacity\" values=\"0;.9;0\" keyTimes=\"0;.3;1\" dur=\"1.5s\" begin=\"10.75s;22.75s\" repeatCount=\"indefinite\"/></circle><circle cx=\"404\" cy=\"69\" r=\"5\" fill=\"#0B0B10\" stroke=\"#FFDD00\" stroke-width=\"1.4\"/><text x=\"389\" y=\"43\" text-anchor=\"end\" font-family=\"Jost\" font-weight=\"600\" font-size=\"11\" letter-spacing=\"1.4\" fill=\"rgba(250,250,253,.95)\">LONDON</text><text x=\"389\" y=\"58\" text-anchor=\"end\" font-family=\"Jost\" font-size=\"8.5\" letter-spacing=\"1\" fill=\"rgba(245,244,248,.7)\">UTC+0</text></g>\n      <text x=\"500\" y=\"496\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"600\" font-size=\"11.5\" letter-spacing=\"2.4\" fill=\"rgba(250,250,253,.88)\">ONE HQ · SEVEN MARKETS · A 24-HOUR DELIVERY DIAL — THE HAND NEVER STOPS</text>\n    </svg>\n      <div class=\"clock-row\">\n        <div class=\"clk\"><b id=\"clkGGN\">--:--</b><span>Gurugram, India · HQ</span></div>\n        <div class=\"clk\"><b id=\"clkRUH\">--:--</b><span>Riyadh</span></div>\n        <div class=\"clk\"><b id=\"clkDXB\">--:--</b><span>Dubai</span></div>\n        <div class=\"clk\"><b id=\"clkLON\">--:--</b><span>London</span></div>\n      </div>\n      <p style=\"text-align:center;margin-top:30px;font-size:15px;color:rgba(250,250,253,.92)\">EaseHawk Technologies Pvt Ltd · WeWork India, DLF Forum, Cybercity Phase III, Gurugram, HR 122002, India &nbsp;·&nbsp; <a href=\"https://www.google.com/maps/search/?api=1&query=WeWork+India,+DLF+Forum,+Cybercity+Phase+III,+Gurugram,+Haryana+122002,+India\" target=\"_blank\" rel=\"noopener\" style=\"color:var(--signal);text-decoration:none\">Get directions →</a></p>\n    </div>\n  </div>\n</section>","<section class=\"chapter\" id=\"faq\" style=\"--acc:#FF810F\">\n  <div class=\"frame chapter-body\">\n    <div style=\"max-width:900px;margin:0 auto;text-align:center\">\n      <div class=\"eyebrow rv\" style=\"justify-content:center\"><b>Before You Write</b> Quick Answers</div>\n      <h2 class=\"display-lg rv rv-d1\">Asked often.<br><span class=\"accent\">Answered straight.</span></h2>\n    </div>\n    <div style=\"max-width:860px;margin:44px auto 0\">\n      <div class=\"faq rv\"><button class=\"faq-q\" type=\"button\">How fast will you actually reply?<span class=\"ind-x\"></span></button>\n        <div class=\"faq-a\"><div><p>Within one business day — and that's a first substantive reply from someone who read your message, not an auto-acknowledgement. Project enquiries come back with relevant case studies attached.</p></div></div></div>\n      <div class=\"faq rv\"><button class=\"faq-q\" type=\"button\">Do you work outside the GCC and India?<span class=\"ind-x\"></span></button>\n        <div class=\"faq-a\"><div><p>Yes — our delivered work spans the UAE, Saudi Arabia, Kuwait, Singapore, the UK, the USA and Canada. <a href=\"/industries\">The Industries page</a> shows exactly what we've shipped where.</p></div></div></div>\n      <div class=\"faq rv\"><button class=\"faq-q\" type=\"button\">Project, embedded squad or retainer — which do I ask for?<span class=\"ind-x\"></span></button>\n        <div class=\"faq-a\"><div><p>If the outcome is fixed, ask for Project Delivery. If you need capacity inside your team, Embedded Squad. If you want long-run ownership, Managed Retainer. Not sure? Pick \"advise me\" in the form and we'll recommend one honestly — or <a href=\"https://calendly.com/easehawk\" target=\"_blank\" rel=\"noopener\">book 30 minutes</a> and we'll figure it out live. Full explainer: <a href=\"/capabilities#models\">the three doors, here</a>.</p></div></div></div>\n      <div class=\"faq rv\"><button class=\"faq-q\" type=\"button\">Can I get something to share internally before a call?<span class=\"ind-x\"></span></button>\n        <div class=\"faq-a\"><div><p>Yes — the glowing hexagon at the bottom-left of every page downloads our company profile. Or ask in the form and we'll send a capability deck matched to your industry.</p></div></div></div>\n      <div class=\"faq rv\"><button class=\"faq-q\" type=\"button\">Are you a services firm or a product company?<span class=\"ind-x\"></span></button>\n        <div class=\"faq-a\"><div><p>Both, deliberately. Seventeen named service engagements pay for the discipline; <a href=\"/moxsuite\">MoxSuite</a> — our AI-native product platform — is where that discipline compounds. Clients get a partner who builds products with the same hands.</p></div></div></div>\n      <div class=\"faq rv\"><button class=\"faq-q\" type=\"button\">What does an engagement cost?<span class=\"ind-x\"></span></button>\n        <div class=\"faq-a\"><div><p>Honestly: it depends on the door — fixed-scope projects, embedded squads and retainers price differently. What we promise is a scoped number after one conversation, not a menu of mystery rates — and no invoice ever surprises you.</p></div></div></div>\n      <div class=\"faq rv\"><button class=\"faq-q\" type=\"button\">Do you sign NDAs?<span class=\"ind-x\"></span></button>\n        <div class=\"faq-a\"><div><p>Yes — yours or ours, usually executed within a day. Our standard NDA is enterprise-grade, built for India-international engagements. Confidentiality isn't a negotiation point; it's the starting line.</p></div></div></div>\n      <div class=\"faq rv\"><button class=\"faq-q\" type=\"button\">How exactly do you use AI in delivery?<span class=\"ind-x\"></span></button>\n        <div class=\"faq-a\"><div><p>AI accelerates our scoping, code review, QA and research — machine speed on the mechanical work, human judgement on every decision and deliverable. Your engagement data stays inside your engagement.</p></div></div></div>\n    </div>\n  </div>\n</section>","<section class=\"chapter\" id=\"ctform\" style=\"--acc:#FFDD00\">\n  <div class=\"frame chapter-body\">\n    <div style=\"text-align:center;max-width:880px;margin:0 auto 40px\">\n      <div class=\"eyebrow rv\" style=\"justify-content:center\"><b>The Form</b> Straight to a Human</div>\n      <h2 class=\"display-xl rv rv-d1\" style=\"font-size:clamp(38px,6vw,96px)\">Say the word.<br><span class=\"accent\">We'll say it back.</span></h2>\n    </div>\n    <div class=\"sla rv rv-d2\"><i></i><span>Every message answered by a human within <b>one business day</b> — reason-tagged, context attached</span></div>\n    <div class=\"sla sla-alt rv rv-d2\" style=\"border-color:rgba(125,125,221,.45);background:rgba(125,125,221,.07);box-shadow:0 0 30px rgba(125,125,221,.16);margin-top:14px\"><i></i><span>Prefer to talk it through? <a href=\"https://calendly.com/easehawk\" target=\"_blank\" rel=\"noopener\" style=\"color:var(--signal);text-decoration:none\">Book 30 minutes on our calendar ↗</a></span></div>\n    <div class=\"glass contact-card rv rv-d3\">\n      <div>\n        <h3 class=\"display-md\" style=\"margin-bottom:14px\">Write to us</h3>\n        <p class=\"thin\" style=\"font-size:14px;max-width:52ch\">If you clicked a door above, we've already tagged your reason. Add a sentence or two — we'll do the digging.</p>\n        <div class=\"contact-list\" style=\"margin-top:32px\">\n          <div class=\"row\"><span class=\"k\">Email</span><span>info@easehawk.com</span></div><div class=\"row\"><span class=\"k\">Call</span><span><a href=\"tel:+17622787611\" style=\"color:inherit;text-decoration:none\">+1 762 278 7611</a> &nbsp;·&nbsp; <a href=\"tel:+919958478569\" style=\"color:inherit;text-decoration:none\">+91 99584 78569</a></span></div><div class=\"row\"><span class=\"k\">Book a Call</span><span><a href=\"https://calendly.com/easehawk\" target=\"_blank\" rel=\"noopener\" style=\"color:var(--signal);text-decoration:none\">calendly.com/easehawk ↗</a></span></div>\n          <div class=\"row\"><span class=\"k\">HQ</span><span>WeWork India · DLF Forum, Cybercity Phase III, Gurugram, HR 122002, India</span></div>\n          <div class=\"row\"><span class=\"k\">Markets</span><span>GCC · India · North America · UK · APAC</span></div>\n          <div class=\"row\"><span class=\"k\">Social</span><span><a class=\"soc\" href=\"https://www.linkedin.com/company/easehawk-technologies/\" target=\"_blank\" rel=\"noopener\"><svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path fill=\"currentColor\" d=\"M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z\"/></svg>EaseHawk Technologies</a></span></div>\n        </div>\n      </div>\n      <form id=\"reqForm\" novalidate>\n        <div class=\"f-grid\">\n          <label class=\"f-field\"><span>Full name *</span><input type=\"text\" name=\"name\" required placeholder=\"Your name\"></label>\n          <label class=\"f-field\"><span>Work email *</span><input type=\"email\" name=\"email\" required placeholder=\"name@company.com\"></label>\n          <label class=\"f-field\"><span>Company</span><input type=\"text\" name=\"company\" placeholder=\"Organisation\"></label>\n          <label class=\"f-field\"><span>Region</span>\n            <select name=\"region\"><option>UAE</option><option>Saudi Arabia</option><option>Qatar</option><option>Kuwait</option><option>USA</option><option>Canada</option><option>UK</option><option>India</option><option>Other</option></select>\n          </label>\n        </div>\n        <div class=\"f-field\" style=\"margin-top:16px\"><span>Reason — pick any</span>\n          <div class=\"f-chips\" id=\"needChips\">\n            <button type=\"button\">New Project</button>\n            <button type=\"button\">Partnership / Reseller</button>\n            <button type=\"button\">Embedded Talent Request</button>\n            <button type=\"button\">MoxSuite / Products</button>\n            <button type=\"button\">Press &amp; Media</button>\n            <button type=\"button\">General</button>\n          </div>\n        </div>\n        <div class=\"f-grid\" style=\"margin-top:16px\">\n          <label class=\"f-field\"><span>Preferred first step</span>\n            <select name=\"timeline\"><option>Intro call</option><option>Detailed proposal</option><option>Live demo</option><option>Just reply by email</option></select>\n          </label>\n          <label class=\"f-field\"><span>Timeline</span>\n            <select name=\"budget\"><option>Urgent — this month</option><option>This quarter</option><option>Next quarter</option><option>Exploring</option></select>\n          </label>\n        </div>\n        <label class=\"f-field\" style=\"margin-top:16px\"><span>Your message *</span>\n          <textarea name=\"message\" rows=\"4\" placeholder=\"A sentence or two is enough — we'll do the digging.\"></textarea>\n        </label>\n        <button class=\"cta\" type=\"submit\" style=\"margin-top:24px;width:100%;text-align:center;justify-content:center\"><span>Send — a human replies in one business day</span></button>\n        <p class=\"f-note\" id=\"formNote\">Opens in your email client, pre-addressed to the EaseHawk team.</p>\n      </form>\n    </div>\n  </div>\n</section>"]