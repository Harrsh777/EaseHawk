["<section class=\"chapter mx-hero\" id=\"cthero\">\n  <div class=\"pin\">\n    <div class=\"headline-wrap\" id=\"heroHead\" style=\"opacity:0;transform:translateY(40px)\">\n      <div class=\"mx-badge\"><i></i>Contact · A Human Replies</div>\n      <h1 class=\"display-xl\">\n        <span class=\"w\"><i>One message.</i></span><br>\n        <span class=\"w\"><i style=\"transition-delay:.12s;color:var(--signal)\">One business day.</i></span>\n      </h1>\n      <p class=\"sub\"><b class=\"sub-lead\">No call centres. No ticket queues. No chatbot maze.</b><span class=\"sub-body\">Write to us and a human who can actually make decisions replies within one business day — with the case studies, pricing signals or straight answers your message deserves. Pick your door below, or go straight to the form.</span></p>\n      <div class=\"mx-counters\">\n        <div class=\"mx-counter\"><b><em class=\"cnt\" data-n=\"1\">0</em></b><span>Business-Day Reply</span></div>\n        <div class=\"mx-counter\"><b class=\"cnt\" data-n=\"0\">0</b><span>Ticket Queues</span></div>\n        <div class=\"mx-counter\"><b class=\"cnt\" data-n=\"6\">0</b><span>Countries Served</span></div>\n        <div class=\"mx-counter\"><b><em class=\"cnt\" data-n=\"17\">0</em></b><span>Named Proofs</span></div>\n      </div>\n      <div class=\"hero-ctas\">\n        <a class=\"cta\" href=\"#ctform\"><span>Write to us</span></a>\n        <a class=\"ghost\" href=\"https://calendly.com/easehawk\" target=\"_blank\" rel=\"noopener\">Book a call ↗</a>\n      </div>\n    </div>\n    <div class=\"scroll-cue\" aria-hidden=\"true\">\n      <svg class=\"cue-hex\" viewBox=\"0 0 44 50\" width=\"34\" height=\"38\">\n        <polygon points=\"22,2 41,13 41,37 22,48 3,37 3,13\" fill=\"rgba(255,221,0,.06)\" stroke=\"#FFDD00\" stroke-width=\"1.6\"/>\n        <g class=\"cue-chevs\" stroke=\"#FFDD00\" stroke-width=\"2.2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M14 17 L22 24 L30 17\"/><path d=\"M14 27 L22 34 L30 27\"/>\n        </g>\n      </svg>\n      <span>Scroll to Enter</span>\n    </div>\n  </div>\n</section>","<section class=\"chapter\" id=\"routes\" style=\"--acc:#FFDD00\">\n  <div class=\"frame chapter-body\">\n    <div style=\"max-width:940px;margin:0 auto;text-align:center\">\n      <div class=\"eyebrow rv\" style=\"justify-content:center\"><b>Four Doors</b> Take the Right One</div>\n      <h2 class=\"display-lg rv rv-d1\">What brings<br><span class=\"accent\">you here?</span></h2>\n      <p class=\"lede rv rv-d2\" style=\"margin:26px auto 0\">One generic form wastes everyone's time. Pick your intent — we'll route it to the right person with the right context already attached.</p>\n    </div>\n    <div class=\"routes-grid\">\n      <a class=\"route rv\" style=\"--pacc:#FFDD00\" href=\"#ctform\" data-route=\"New Project\">\n        <div class=\"r-k\">Door 01</div>\n        <span class=\"r-ic\">◆</span>\n        <h4>Start a Project</h4>\n        <p>Engineering, AI, CRM, data or creative — tell us what you're building and get sector-matched case studies with our reply. Napkin-stage ideas welcome; scoping is what the first call is for.</p>\n        <span class=\"sc-read\">To the form, pre-tagged <b class=\"ar\">→</b></span>\n      </a>\n      <a class=\"route rv\" style=\"--pacc:#FF810F\" href=\"#ctform\" data-route=\"Partnership / Reseller\">\n        <div class=\"r-k\">Door 02</div>\n        <span class=\"r-ic\">⬡</span>\n        <h4>Partner With Us</h4>\n        <p>Channel partnerships, reseller arrangements, or embedding our specialists through your firm — Protiviti and Alpha Data already do. Built channel-friendly from day one.</p>\n        <span class=\"sc-read\">To the form, pre-tagged <b class=\"ar\">→</b></span>\n      </a>\n      <a class=\"route rv\" style=\"--pacc:#7D7DDD\" href=\"/careers\">\n        <div class=\"r-k\">Door 03</div>\n        <span class=\"r-ic\">▲</span>\n        <h4>Join the Team</h4>\n        <p>Four open AI and data roles, written as mission briefs — what you'll ship in 90 days, the bar we screen against, and a 48-hour acknowledgement in writing.</p>\n        <span class=\"sc-read\">To the careers page <b class=\"ar\">→</b></span>\n      </a>\n      <a class=\"route rv\" style=\"--pacc:#FFDD00\" href=\"/moxsuite\">\n        <div class=\"r-k\">Door 04</div>\n        <span class=\"r-ic\">◈</span>\n        <h4>MoxSuite &amp; Products</h4>\n        <p>Early access, pilots or demos of our AI product platform — MoxSend, MoxCRM, MoxQuote, MoxFinance, MoxCampus, MoxRev. Six products, one intelligence core.</p>\n        <span class=\"sc-read\">To the platform <b class=\"ar\">→</b></span>\n      </a>\n    </div>\n  </div>\n</section>","<section class=\"chapter\" id=\"presence\" style=\"--acc:#FFDD00\">\n  <div class=\"frame chapter-body\">\n    <div style=\"max-width:900px;margin:0 auto;text-align:center\">\n      <div class=\"eyebrow rv\" style=\"justify-content:center\"><b>Where We Are</b> When You Are</div>\n      <h2 class=\"display-lg rv rv-d1\">Awake when<br><span class=\"accent\">your market is.</span></h2>\n      <p class=\"lede rv rv-d2\" style=\"margin:26px auto 0\">Headquartered in Gurugram, India, delivering across six countries. The dial below runs a full day every twelve seconds — if your city is on it, your hours are ours. The clocks are live.</p>\n    </div>\n    <div class=\"glass rv rv-d3\" style=\"margin-top:44px;padding:clamp(24px,3vw,44px);border-radius:20px\">\n      <svg viewBox=\"0 0 1000 505\" style=\"width:100%;height:auto\" aria-hidden=\"true\">\n      <defs>\n        <radialGradient id=\"sunG\"><stop offset=\"0\" stop-color=\"#FFF3B0\"/><stop offset=\".3\" stop-color=\"#FFDD00\"/><stop offset=\"1\" stop-color=\"rgba(255,129,15,0)\"/></radialGradient>\n        <linearGradient id=\"beamG\" x1=\"500\" y1=\"235\" x2=\"500\" y2=\"29\" gradientUnits=\"userSpaceOnUse\">\n          <stop offset=\"0\" stop-color=\"rgba(255,221,0,0)\"/><stop offset=\".55\"