["<section class=\"chapter mx-hero\" id=\"indhero\">\n  <div class=\"pin\">\n    <div class=\"headline-wrap\" id=\"heroHead\" style=\"opacity:0;transform:translateY(40px)\">\n      <div class=\"mx-badge\"><i></i>Industries · Sector Fluency, Proven</div>\n      <h1 class=\"display-xl\">\n        <span class=\"w\"><i>We speak</i></span><br>\n        <span class=\"w\"><i style=\"transition-delay:.12s;color:var(--signal)\">your industry.</i></span>\n      </h1>\n      <p class=\"sub\"><b class=\"sub-lead\">Eight sectors. Every one entered through delivered work.</b><span class=\"sub-body\">A federal ministry buys differently than a fleet operator. A manufacturer measures differently than a fintech. Below, every industry we serve — with the named clients and case studies that earned us the room, and AI woven into how we deliver in each.</span></p>\n      <div class=\"mx-counters\">\n        <div class=\"mx-counter\"><b><em class=\"cnt\" data-n=\"8\">0</em></b><span>Industries Served</span></div>\n        <div class=\"mx-counter\"><b class=\"cnt\" data-n=\"17\">0</b><span>Engagements</span></div>\n        <div class=\"mx-counter\"><b class=\"cnt\" data-n=\"6\">0</b><span>Countries</span></div>\n        <div class=\"mx-counter\"><b><em class=\"cnt\" data-n=\"2\">0</em></b><span>Industry Platforms</span></div>\n      </div>\n      <div class=\"hero-ctas\">\n        <a class=\"cta\" href=\"#sectors\"><span>Find your sector</span></a>\n        <a class=\"ghost\" href=\"#indcontact\">Talk to us</a>\n      </div>\n    </div>\n    <div class=\"scroll-cue\" aria-hidden=\"true\">\n      <svg class=\"cue-hex\" viewBox=\"0 0 44 50\" width=\"34\" height=\"38\">\n        <polygon points=\"22,2 41,13 41,37 22,48 3,37 3,13\" fill=\"rgba(255,221,0,.06)\" stroke=\"#FFDD00\" stroke-width=\"1.6\"/>\n        <g class=\"cue-chevs\" stroke=\"#FFDD00\" stroke-width=\"2.2\" fill=\"none\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M14 17 L22 24 L30 17\"/><path d=\"M14 27 L22 34 L30 27\"/>\n        </g>\n      </svg>\n      <span>Scroll to Enter</span>\n    </div>\n  </div>\n</section>","<section class=\"chapter\" id=\"sectors\" style=\"--acc:#FFDD00\">\n  <div class=\"frame chapter-body\">\n    <div style=\"max-width:940px;margin:0 auto;text-align:center\">\n      <div class=\"eyebrow rv\" style=\"justify-content:center\"><b>The Sector Index</b> Open Your Room</div>\n      <h2 class=\"display-lg rv rv-d1\">Eight industries.<br><span class=\"accent\">Earned, not claimed.</span></h2>\n      <p class=\"lede rv rv-d2\" style=\"margin:26px auto 0\">Every row below opens into a sector briefing — what we bring, who trusted us, and direct links into the case studies. No sector appears here without shipped work behind it.</p>\n    </div>\n    <div class=\"ticker rv rv-d3\" aria-hidden=\"true\"><div class=\"tk\"><span class=\"gv\">ADNOC</span><i>◆</i><span class=\"gv\">Ministry of Culture — UAE</span><i>◆</i><span class=\"gv\">Ministry of Minerals — KSA</span><i>◆</i><span class=\"gv\">Ministry of Health — KSA</span><i>◆</i><span class=\"gv\">Abu Dhabi Aviation</span><i>◆</i><span>Amazon Payment Services</span><i>◆</i><span>SAP</span><i>◆</i><span>SERCO</span><i>◆</i><span>Protiviti</span><i>◆</i><span>UTAC</span><i>◆</i><span>Petromin</span><i>◆</i><span>Fine Hygienic</span><i>◆</i><span>Tigo Energy</span><i>◆</i><span>Towell International</span><i>◆</i><span>Mattex</span><i>◆</i><span>Acquis</span><i>◆</i><span>Viita</span><i>◆</i><span>White City</span><i>◆</i><span>Mega Prime Foods</span><i>◆</i><span>Bhumi</span><i>◆</i><span>Alpha Data</span><i>◆</i><span>Ducker Carlisle</span><i>◆</i><span class=\"gv\">ADNOC</span><i>◆</i><span class=\"gv\">Ministry of Culture — UAE</span><i>◆</i><span class=\"gv\">Ministry of Minerals — KSA</span><i>◆</i><span class=\"gv\">Ministry of Health — KSA</span><i>◆</i><span class=\"gv\">Abu Dhabi Aviation</span><i>◆</i><span>Amazon Payment Services</span><i>◆</i><span>SAP</span><i>◆</i><span>SERCO</span><i>◆</i><span>Protiviti</span><i>◆</i><span>UTAC</span><i>◆</i><span>Petromin</span><i>◆</i><span>Fine Hygienic</span><i>◆</i><span>Tigo Energy</span><i>◆</i><span>Towell International</span><i>◆</i><span>Mattex</span><i>◆</i><span>Acquis</span><i>◆</i><span>Viita</span><i>◆</i><span>White City</span><i>◆</i><span>Mega Prime Foods</span><i>◆</i><span>Bhumi</span><i>◆</i><span>Alpha Data</span><i>◆</i><span>Ducker Carlisle</span><i>◆</i></div></div>\n    <div style=\"margin-top:40px\">\n    <div class=\"ind rv\" style=\"--pacc:#FFDD00;--acc:#FFDD00\">\n      <button class=\"ind-head\" type=\"button\" aria-expanded=\"false\">\n        <span class=\"ind-num\">01</span>\n        <span class=\"ind-name\">Government &amp; Public Sector</span>\n        <span class=\"ind-count\">3 Case Studies · 6 Clients</span>\n        <span class=\"ind-x\" aria-hidden=\"true\"></span>\n      </button>\n      <div class=\"ind-body\"><div class=\"ind-inner\">\n        <div class=\"ind-grid\">\n          <div class=\"ind-snap\"><span><b>3</b><small>Case Studies</small></span><span><b>6</b><small>Clients</small></span><span><b>UAE · KSA</b><small>Markets</small></span></div>\n          <div>\n            <p class=\"ind-blurb\">Federal ministries, national operators and state-linked ventures — environments where procurement is formal, standards are non-negotiable and a wrong partner costs a programme, not a project. We've delivered through the channels these institutions already trust: Alpha Data, Protiviti.</p>\n            <div class=\"ai-line\"><b>◆</b>AI, Delivered at Government Grade — Vetted Channels, Cleared Teams</div>\n            <div class=\"tagrow\" style=\"margin-top:20px\"><span>Digital Transformation</span><span>Embedded Specialists</span><span>Dynamics 365</span><span>Secure Delivery</span></div>\n            <a class=\"ghost\" href=\"#indcontact\" style=\"margin-top:26px;display:inline-flex;align-items:center;padding:13px 26px\">Discuss your industry</a>\n          </div>\n          <div>\n            <div class=\"ev-h\">Case Studies — Open the Proof</div>\n            <div class=\"case-chips\"><a class=\"case-chip\" href=\"/success-stories#case-serco\"><b>SERCO — NOC Transformation</b><span>9 mo · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-moculture\"><b>Ministry of Culture — D365 Architects</b><span>6 mo · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-adnoc\"><b>ADNOC-Fertiglobe — Specialists</b><span>6 mo · Open case →</span></a></div>\n            <div class=\"ev-h\" style=\"margin-top:34px\">Clients In This Sector</div>\n            <div class=\"cl-pills\"><span class=\"cl-pill\">Ministry of Culture — UAE</span><span class=\"cl-pill\">Ministry of Minerals — KSA</span><span class=\"cl-pill\">Ministry of Health — KSA</span><span class=\"cl-pill\">Abu Dhabi Aviation</span><span class=\"cl-pill\">SERCO</span><span class=\"cl-pill\">ADNOC</span></div>\n          </div>\n        </div>\n      </div></div>\n    </div>\n    <div class=\"ind rv\" style=\"--pacc:#FF810F;--acc:#FF810F\">\n      <button class=\"ind-head\" type=\"button\" aria-expanded=\"false\">\n        <span class=\"ind-num\">02</span>\n        <span class=\"ind-name\">Energy &amp; Utilities</span>\n        <span class=\"ind-count\">2 Case Studies · 3 Clients</span>\n        <span class=\"ind-x\" aria-hidden=\"true\"></span>\n      </button>\n      <div class=\"ind-body\"><div class=\"ind-inner\">\n        <div class=\"ind-grid\">\n          <div class=\"ind-snap\"><span><b>2</b><small>Case Studies</small></span><span><b>3</b><small>Clients</small></span><span><b>UAE · USA · KSA</b><small>Markets</small></span></div>\n          <div>\n            <p class=\"ind-blurb\">From the world's largest energy joint ventures to NASDAQ-listed solar technology — a sector where uptime is culture and every partner is measured against operators. Our longest creative engagement and our most demanding embedded placement both live here.</p>\n            <div class=\"ai-line\"><b>◆</b>AI-Assisted Delivery Inside Operator-Grade Environments</div>\n            <div class=\"tagrow\" style=\"margin-top:20px\"><span>Embedded Talent</span><span>Product Video Programmes</span><span>Enterprise Delivery</span></div>\n            <a class=\"ghost\" href=\"#indcontact\" style=\"margin-top:26px;display:inline-flex;align-items:center;padding:13px 26px\">Discuss your industry</a>\n          </div>\n          <div>\n            <div class=\"ev-h\">Case Studies — Open the Proof</div>\n            <div class=\"case-chips\"><a class=\"case-chip\" href=\"/success-stories#case-adnoc\"><b>ADNOC-Fertiglobe — Specialists via Protiviti</b><span>6 mo · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-tigo\"><b>Tigo Energy — 3-Year Video Programme</b><span>3 yrs · Open case →</span></a></div>\n            <div class=\"ev-h\" style=\"margin-top:34px\">Clients In This Sector</div>\n            <div class=\"cl-pills\"><span class=\"cl-pill\">ADNOC</span><span class=\"cl-pill\">Tigo Energy</span><span class=\"cl-pill\">Petromin</span></div>\n          </div>\n        </div>\n      </div></div>\n    </div>\n    <div class=\"ind rv\" style=\"--pacc:#7D7DDD;--acc:#7D7DDD\">\n      <button class=\"ind-head\" type=\"button\" aria-expanded=\"false\">\n        <span class=\"ind-num\">03</span>\n        <span class=\"ind-name\">Manufacturing &amp; Industrial</span>\n        <span class=\"ind-count\">2 Case Studies · 2 Clients</span>\n        <span class=\"ind-x\" aria-hidden=\"true\"></span>\n      </button>\n      <div class=\"ind-body\"><div class=\"ind-inner\">\n        <div class=\"ind-grid\">\n          <div class=\"ind-snap\"><span><b>2</b><small>Case Studies</small></span><span><b>2</b><small>Clients</small></span><span><b>KSA</b><small>Market</small></span></div>\n          <div>\n            <p class=\"ind-blurb\">Thirty-year manufacturing groups and Saudi industrial houses modernising the way they sell, operate and communicate. We run multi-year digital ecosystems here — including a bilingual AI assistant in daily production.</p>\n            <div class=\"ai-line\"><b>◆</b>AI in Production — Not in the Pitch Deck</div>\n            <div class=\"tagrow\" style=\"margin-top:20px\"><span>Digital Ecosystems</span><span>AI Chatbots EN/AR</span><span>Dynamics 365</span><span>Retained Delivery</span></div>\n            <a class=\"ghost\" href=\"#indcontact\" style=\"margin-top:26px;display:inline-flex;align-items:center;padding:13px 26px\">Discuss your industry</a>\n          </div>\n          <div>\n            <div class=\"ev-h\">Case Studies — Open the Proof</div>\n            <div class=\"case-chips\"><a class=\"case-chip\" href=\"/success-stories#case-mattex\"><b>Mattex — Full Digital Ecosystem</b><span>2+ yrs · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-alruqee\"><b>Alruqee — Dynamics 365</b><span>9 mo · Open case →</span></a></div>\n            <div class=\"ev-h\" style=\"margin-top:34px\">Clients In This Sector</div>\n            <div class=\"cl-pills\"><span class=\"cl-pill\">Mattex</span><span class=\"cl-pill\">Alruqee</span></div>\n          </div>\n        </div>\n      </div></div>\n    </div>\n    <div class=\"ind rv\" style=\"--pacc:#FFDD00;--acc:#FFDD00\">\n      <button class=\"ind-head\" type=\"button\" aria-expanded=\"false\">\n        <span class=\"ind-num\">04</span>\n        <span class=\"ind-name\">Financial Services &amp; Insurance</span>\n        <span class=\"ind-count\">3 Case Studies · 3 Clients</span>\n        <span class=\"ind-x\" aria-hidden=\"true\"></span>\n      </button>\n      <div class=\"ind-body\"><div class=\"ind-inner\">\n        <div class=\"ind-grid\">\n          <div class=\"ind-snap\"><span><b>3</b><small>Case Studies</small></span><span><b>3</b><small>Clients</small></span><span><b>UK · CA · MENA</b><small>Markets</small></span></div>\n          <div>\n            <p class=\"ind-blurb\">Payments giants, European finance groups and North American insurers — regulated businesses where the CRM is the business and every workflow carries compliance weight. We build the backbones and keep them AI-ready.</p>\n            <div class=\"ai-line\"><b>◆</b>AI-Ready Revenue Systems for Regulated Businesses</div>\n            <div class=\"tagrow\" style=\"margin-top:20px\"><span>Salesforce</span><span>Customer Portals</span><span>Campaign Programmes</span><span>Process Automation</span></div>\n            <a class=\"ghost\" href=\"#indcontact\" style=\"margin-top:26px;display:inline-flex;align-items:center;padding:13px 26px\">Discuss your industry</a>\n          </div>\n          <div>\n            <div class=\"ev-h\">Case Studies — Open the Proof</div>\n            <div class=\"case-chips\"><a class=\"case-chip\" href=\"/success-stories#case-acquis\"><b>Acquis — Salesforce Implementation</b><span>9 mo · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-viita\"><b>Viita — Insurance Portal</b><span>2 yrs · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-aps\"><b>Amazon Payment Services — Campaigns</b><span>2 yrs · Open case →</span></a></div>\n            <div class=\"ev-h\" style=\"margin-top:34px\">Clients In This Sector</div>\n            <div class=\"cl-pills\"><span class=\"cl-pill\">Amazon Payment Services</span><span class=\"cl-pill\">Acquis</span><span class=\"cl-pill\">Viita</span></div>\n          </div>\n        </div>\n      </div></div>\n    </div>\n    <div class=\"ind rv\" style=\"--pacc:#FF810F;--acc:#FF810F\">\n      <button class=\"ind-head\" type=\"button\" aria-expanded=\"false\">\n        <span class=\"ind-num\">05</span>\n        <span class=\"ind-name\">Logistics &amp; Mobility</span>\n        <span class=\"ind-count\">1 Case Study · 1 Client</span>\n        <span class=\"ind-x\" aria-hidden=\"true\"></span>\n      </button>\n      <div class=\"ind-body\"><div class=\"ind-inner\">\n        <div class=\"ind-grid\">\n          <div class=\"ind-snap\"><span><b>1</b><small>Flagship Case</small></span><span><b>~80%</b><small>Ops Automated</small></span><span><b>USA</b><small>Market</small></span></div>\n          <div>\n            <p class=\"ind-blurb\">Fleet operators where margin lives in minutes and manual dispatch eats it daily. Our flagship automation story is here: a 50+ truck US operation running roughly 80% of daily operations without human touch.</p>\n            <div class=\"ai-line\"><b>◆</b>AI as an Operating Decision — ~80% of Daily Ops Automated</div>\n            <div class=\"tagrow\" style=\"margin-top:20px\"><span>Dispatch Automation</span><span>Fleet Telemetry</span><span>Back-Office Automation</span><span>Analytics</span></div>\n            <a class=\"ghost\" href=\"#indcontact\" style=\"margin-top:26px;display:inline-flex;align-items:center;padding:13px 26px\">Discuss your industry</a>\n          </div>\n          <div>\n            <div class=\"ev-h\">Case Studies — Open the Proof</div>\n            <div class=\"case-chips\"><a class=\"case-chip\" href=\"/success-stories#case-whitecity\"><b>White City — 80% Automated Operations</b><span>2 yrs · Open case →</span></a></div>\n            <div class=\"ev-h\" style=\"margin-top:34px\">Clients In This Sector</div>\n            <div class=\"cl-pills\"><span class=\"cl-pill\">White City</span></div>\n          </div>\n        </div>\n      </div></div>\n    </div>\n    <div class=\"ind rv\" style=\"--pacc:#7D7DDD;--acc:#7D7DDD\">\n      <button class=\"ind-head\" type=\"button\" aria-expanded=\"false\">\n        <span class=\"ind-num\">06</span>\n        <span class=\"ind-name\">Technology &amp; Semiconductors</span>\n        <span class=\"ind-count\">2 Case Studies · 3 Clients</span>\n        <span class=\"ind-x\" aria-hidden=\"true\"></span>\n      </button>\n      <div class=\"ind-body\"><div class=\"ind-inner\">\n        <div class=\"ind-grid\">\n          <div class=\"ind-snap\"><span><b>2</b><small>Case Studies</small></span><span><b>3</b><small>Clients</small></span><span><b>SG · Global</b><small>Markets</small></span></div>\n          <div>\n            <p class=\"ind-blurb\">Global software leaders and semiconductor manufacturers — audiences that see through vendor theatre instantly. SAP trusted us to explain its startup ecosystem; UTAC embedded our BI specialist inside fab-speed decision-making for a full year.</p>\n            <div class=\"ai-line\"><b>◆</b>Technical Fluency, Proven Inside Technical Companies</div>\n            <div class=\"tagrow\" style=\"margin-top:20px\"><span>Embedded BI</span><span>Power BI</span><span>Explainer Programmes</span><span>Data Foundations</span></div>\n            <a class=\"ghost\" href=\"#indcontact\" style=\"margin-top:26px;display:inline-flex;align-items:center;padding:13px 26px\">Discuss your industry</a>\n          </div>\n          <div>\n            <div class=\"ev-h\">Case Studies — Open the Proof</div>\n            <div class=\"case-chips\"><a class=\"case-chip\" href=\"/success-stories#case-sap\"><b>SAP — Startup Ecosystem Films</b><span>2 yrs · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-utac\"><b>UTAC — Embedded Power BI</b><span>1 yr · Open case →</span></a></div>\n            <div class=\"ev-h\" style=\"margin-top:34px\">Clients In This Sector</div>\n            <div class=\"cl-pills\"><span class=\"cl-pill\">SAP</span><span class=\"cl-pill\">UTAC</span><span class=\"cl-pill\">Alpha Data</span></div>\n          </div>\n        </div>\n      </div></div>\n    </div>\n    <div class=\"ind rv\" style=\"--pacc:#FFDD00;--acc:#FFDD00\">\n      <button class=\"ind-head\" type=\"button\" aria-expanded=\"false\">\n        <span class=\"ind-num\">07</span>\n        <span class=\"ind-name\">Consumer, FMCG &amp; Food</span>\n        <span class=\"ind-count\">3 Case Studies · 3 Clients</span>\n        <span class=\"ind-x\" aria-hidden=\"true\"></span>\n      </button>\n      <div class=\"ind-body\"><div class=\"ind-inner\">\n        <div class=\"ind-grid\">\n          <div class=\"ind-snap\"><span><b>3</b><small>Case Studies</small></span><span><b>3</b><small>Clients</small></span><span><b>MENA · APAC · KW</b><small>Markets</small></span></div>\n          <div>\n            <p class=\"ind-blurb\">Household brands and multi-market food companies competing for attention across cultures. One brand voice, executed market-natively — with AI-assisted localisation running four adaptations in parallel while the craft stays human.</p>\n            <div class=\"ai-line\"><b>◆</b>AI-Assisted Localisation — One Brand, Every Market</div>\n            <div class=\"tagrow\" style=\"margin-top:20px\"><span>Brand Films</span><span>Multi-Market Campaigns</span><span>Cultural Adaptation</span><span>Corporate Platforms</span></div>\n            <a class=\"ghost\" href=\"#indcontact\" style=\"margin-top:26px;display:inline-flex;align-items:center;padding:13px 26px\">Discuss your industry</a>\n          </div>\n          <div>\n            <div class=\"ev-h\">Case Studies — Open the Proof</div>\n            <div class=\"case-chips\"><a class=\"case-chip\" href=\"/success-stories#case-fine\"><b>Fine Hygienic — Brand Film + Campaigns</b><span>2 yrs · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-megaprime\"><b>Mega Prime Foods — 4-Market Campaign</b><span>1 yr · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-towell\"><b>Towell International — 3 Platforms</b><span>1 yr · Open case →</span></a></div>\n            <div class=\"ev-h\" style=\"margin-top:34px\">Clients In This Sector</div>\n            <div class=\"cl-pills\"><span class=\"cl-pill\">Fine Hygienic</span><span class=\"cl-pill\">Mega Prime Foods</span><span class=\"cl-pill\">Towell International</span></div>\n          </div>\n        </div>\n      </div></div>\n    </div>\n    <div class=\"ind rv\" style=\"--pacc:#FF810F;--acc:#FF810F\">\n      <button class=\"ind-head\" type=\"button\" aria-expanded=\"false\">\n        <span class=\"ind-num\">08</span>\n        <span class=\"ind-name\">Non-Profit &amp; Social Impact</span>\n        <span class=\"ind-count\">2 Case Studies · 1 Client</span>\n        <span class=\"ind-x\" aria-hidden=\"true\"></span>\n      </button>\n      <div class=\"ind-body\"><div class=\"ind-inner\">\n        <div class=\"ind-grid\">\n          <div class=\"ind-snap\"><span><b>2</b><small>Case Studies</small></span><span><b>1</b><small>Client, Twice</small></span><span><b>India</b><small>Market</small></span></div>\n          <div>\n            <p class=\"ind-blurb\">Mission-driven organisations coordinating people at enterprise scale on non-enterprise budgets. We've delivered for one of India's largest volunteer movements twice — CRM and engineering capacity, both sized to the mission.</p>\n            <div class=\"ai-line\"><b>◆</b>Enterprise Discipline at Mission-Scale Budgets</div>\n            <div class=\"tagrow\" style=\"margin-top:20px\"><span>Zoho CRM</span><span>Developer Augmentation</span><span>Automation</span></div>\n            <a class=\"ghost\" href=\"#indcontact\" style=\"margin-top:26px;display:inline-flex;align-items:center;padding:13px 26px\">Discuss your industry</a>\n          </div>\n          <div>\n            <div class=\"ev-h\">Case Studies — Open the Proof</div>\n            <div class=\"case-chips\"><a class=\"case-chip\" href=\"/success-stories#case-bhumi-zoho\"><b>Bhumi — Zoho CRM</b><span>6 mo · Open case →</span></a><a class=\"case-chip\" href=\"/success-stories#case-bhumi-dev\"><b>Bhumi — Engineering Squad</b><span>3 mo · Open case →</span></a></div>\n            <div class=\"ev-h\" style=\"margin-top:34px\">Clients In This Sector</div>\n            <div class=\"cl-pills\"><span class=\"cl-pill\">Bhumi</span></div>\n          </div>\n        </div>\n      </div></div>\n    </div>\n    </div>\n\n    <div style=\"max-width:900px;margin:80px auto 0;text-align:center\">\n      <div class=\"eyebrow rv\" style=\"justify-content:center\"><b>Going Deeper</b> Platform Industries</div>\n      <h2 class=\"display-lg rv rv-d1\" style=\"font-size:clamp(26px,3.6vw,52px)\">Two sectors, we didn't stop<br><span class=\"accent\">at services.</span></h2>\n      <p class=\"lede rv rv-d2\" style=\"margin:22px auto 0\">Where we saw industry-wide problems, we built full AI-native platforms — not projects.</p>\n    </div>\n    <div class=\"plat-mini\">\n      <a class=\"pm rv\" style=\"--pacc:#FFDD00\" href=\"/moxsuite\">\n        <div class=\"pm-k\">Education</div>\n        <h4>MoxCampus</h4>\n        <p>The AI operating system for independent schools — admissions to alumni, predictive AI on every student journey, multi-tenant for school groups.</p>\n        <span class=\"sc-read\">Explore the platform <b class=\"ar\">→</b></span>\n      </a>\n      <a class=\"pm rv\" style=\"--pacc:#FF810F\" href=\"/moxsuite\">\n        <div class=\"pm-k\">Automotive</div>\n        <h4>MoxRev</h4>\n        <p>The AI operating system for dealerships and rental fleets — AI dynamic pricing, utilisation intelligence, both sides of the lot on one platform.</p>\n        <span class=\"sc-read\">Explore the platform <b class=\"ar\">→</b></span>\n      </a>\n    </div>\n    <div class=\"suite-strip rv\">\n      <span class=\"ss-k\">Plus one horizontal AI suite serving every sector on this page</span>\n      <span class=\"ss-names\"><b>MoxSend</b><i>◆</i><b>MoxCRM</b><i>◆</i><b>MoxQuote</b><i>◆</i><b>MoxFinance</b></span>\n      <a class=\"sc-read\" href=\"/moxsuite\" style=\"padding-top:0;margin-top:0\">Explore MoxSuite <b class=\"ar\">→</b></a>\n    </div>\n  </div>\n</section>","<section class=\"chapter\" id=\"indcontact\" style=\"--acc:#FFDD00\">\n  <div class=\"frame chapter-body\">\n    <div style=\"text-align:center;max-width:880px;margin:0 auto 60px\">\n      <div class=\"eyebrow rv\" style=\"justify-content:center\"><b>Your Sector</b> One Business Day</div>\n      <h2 class=\"display-xl rv rv-d1\" style=\"font-size:clamp(38px,6vw,96px)\">Let's talk<br><span class=\"accent\">your language.</span></h2>\n      <p class=\"lede rv rv-d2\" style=\"margin:26px auto 0\">Tell us your industry and what you're building. We'll reply within one business day — with the case studies from your sector attached, not a generic brochure.</p>\n    </div>\n    <div class=\"glass contact-card rv rv-d3\">\n      <div>\n        <h3 class=\"display-md\" style=\"margin-bottom:14px\">Start the conversation</h3>\n        <p class=\"thin\" style=\"font-size:14px;max-width:52ch\">Pick the capabilities you need — we'll bring the sector context ourselves.</p>\n        <div class=\"contact-list\" style=\"margin-top:32px\">\n          <div class=\"row\"><span class=\"k\">Email</span><span>info@easehawk.com</span></div><div class=\"row\"><span class=\"k\">Call</span><span><a href=\"tel:+17622787611\" style=\"color:inherit;text-decoration:none\">+1 762 278 7611</a> &nbsp;·&nbsp; <a href=\"tel:+919958478569\" style=\"color:inherit;text-decoration:none\">+91 99584 78569</a></span></div><div class=\"row\"><span class=\"k\">Book a Call</span><span><a href=\"https://calendly.com/easehawk\" target=\"_blank\" rel=\"noopener\" style=\"color:var(--signal);text-decoration:none\">calendly.com/easehawk ↗</a></span></div>\n          <div class=\"row\"><span class=\"k\">Markets</span><span>GCC · India · North America · UK · APAC</span></div>\n          <div class=\"row\"><span class=\"k\">HQ</span><span>EaseHawk · WeWork DLF Forum, Cybercity, Gurugram, India</span></div>\n          <div class=\"row\"><span class=\"k\">Social</span><span><a class=\"soc\" href=\"https://www.linkedin.com/company/easehawk\" target=\"_blank\" rel=\"noopener\"><svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path fill=\"currentColor\" d=\"M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z\"/></svg>EaseHawk Technologies</a></span></div>\n        </div>\n      </div>\n      <form id=\"reqForm\" novalidate>\n        <div class=\"f-grid\">\n          <label class=\"f-field\"><span>Full name *</span><input type=\"text\" name=\"name\" required placeholder=\"Your name\"></label>\n          <label class=\"f-field\"><span>Work email *</span><input type=\"email\" name=\"email\" required placeholder=\"name@company.com\"></label>\n          <label class=\"f-field\"><span>Company</span><input type=\"text\" name=\"company\" placeholder=\"Organisation\"></label>\n          <label class=\"f-field\"><span>Region</span>\n            <select name=\"region\"><option>UAE</option><option>Saudi Arabia</option><option>Qatar</option><option>Kuwait</option><option>USA</option><option>Canada</option><option>UK</option><option>India</option><option>Other</option></select>\n          </label>\n        </div>\n        <div class=\"f-field\" style=\"margin-top:16px\"><span>Which capabilities? — pick any</span>\n          <div class=\"f-chips\" id=\"needChips\">\n            <button type=\"button\">Software Engineering</button>\n            <button type=\"button\">AI &amp; Automation</button>\n            <button type=\"button\">CRM &amp; Enterprise</button>\n            <button type=\"button\">Data &amp; BI</button>\n            <button type=\"button\">Brand &amp; Video</button>\n            <button type=\"button\">Embedded Talent</button>\n          </div>\n        </div>\n        <div class=\"f-grid\" style=\"margin-top:16px\">\n          <label class=\"f-field\"><span>Engagement model</span>\n            <select name=\"timeline\"><option>Project Delivery</option><option>Embedded Squad</option><option>Managed Retainer</option><option>Not sure yet — advise me</option></select>\n          </label>\n          <label class=\"f-field\"><span>Timeline</span>\n            <select name=\"budget\"><option>Urgent — this month</option><option>This quarter</option><option>Next quarter</option><option>Exploring</option></select>\n          </label>\n        </div>\n        <label class=\"f-field\" style=\"margin-top:16px\"><span>Your industry &amp; what you're building</span>\n          <textarea name=\"message\" rows=\"4\" placeholder=\"e.g. Saudi manufacturing group — we need our commercial operations on one platform.\"></textarea>\n        </label>\n        <button class=\"cta\" type=\"submit\" style=\"margin-top:24px;width:100%;text-align:center;justify-content:center\"><span>Get my sector-matched case studies</span></button>\n        <p class=\"f-note\" id=\"formNote\">Opens in your email client, pre-addressed to the EaseHawk team. Reply within one business day.</p>\n      </form>\n    </div>\n  </div>\n</section>"]