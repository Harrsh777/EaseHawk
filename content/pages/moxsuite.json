"/></circle>\n          <polygon points=\"230,170 282,200 282,260 230,290 178,260 178,200\" fill=\"rgba(10,10,16,.96)\" stroke=\"url(#axG)\" stroke-width=\"1.8\"/>\n          <polygon points=\"230,170 282,200 282,260 230,290 178,260 178,200\" fill=\"none\" stroke=\"#FFDD00\" stroke-width=\".8\" stroke-dasharray=\"5 8\" opacity=\".6\">\n            <animateTransform attributeName=\"transform\" type=\"rotate\" values=\"0 230 230;360 230 230\" dur=\"24s\" repeatCount=\"indefinite\"/></polygon>\n          <text x=\"230\" y=\"224\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"700\" font-size=\"13.5\" letter-spacing=\"1.6\" fill=\"#fff\">MOXSUITE</text>\n          <text x=\"230\" y=\"244\" text-anchor=\"middle\" font-family=\"Jost\" font-size=\"7\" letter-spacing=\"1.1\" fill=\"rgba(245,244,248,.75)\">INTELLIGENCE CORE</text>\n          <g><rect x=\"179\" y=\"39\" width=\"102\" height=\"26\" rx=\"13.0\" fill=\"rgba(10,10,16,.95)\" stroke=\"#FFDD00\" stroke-opacity=\".8\" stroke-width=\"1\"/><text x=\"230\" y=\"55\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"600\" font-size=\"8.5\" letter-spacing=\"1\" fill=\"#fff\">MOXSEND</text></g><g><rect x=\"333\" y=\"128\" width=\"102\" height=\"26\" rx=\"13.0\" fill=\"rgba(10,10,16,.95)\" stroke=\"#FF810F\" stroke-opacity=\".8\" stroke-width=\"1\"/><text x=\"384\" y=\"144\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"600\" font-size=\"8.5\" letter-spacing=\"1\" fill=\"#fff\">MOXWARM</text></g><g><rect x=\"333\" y=\"306\" width=\"102\" height=\"26\" rx=\"13.0\" fill=\"rgba(10,10,16,.95)\" stroke=\"#7D7DDD\" stroke-opacity=\".8\" stroke-width=\"1\"/><text x=\"384\" y=\"322\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"600\" font-size=\"8.5\" letter-spacing=\"1\" fill=\"#fff\">MOXCHECK</text></g><g><rect x=\"179\" y=\"395\" width=\"102\" height=\"26\" rx=\"13.0\" fill=\"rgba(10,10,16,.95)\" stroke=\"#FFDD00\" stroke-opacity=\".8\" stroke-width=\"1\"/><text x=\"230\" y=\"411\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"600\" font-size=\"8.5\" letter-spacing=\"1\" fill=\"#fff\">MOXCRM</text></g><g><rect x=\"25\" y=\"306\" width=\"102\" height=\"26\" rx=\"13.0\" fill=\"rgba(10,10,16,.95)\" stroke=\"#FF810F\" stroke-opacity=\".8\" stroke-width=\"1\"/><text x=\"76\" y=\"322\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"600\" font-size=\"8.5\" letter-spacing=\"1\" fill=\"#fff\">MOXQUOTE</text></g><g><rect x=\"25\" y=\"128\" width=\"102\" height=\"26\" rx=\"13.0\" fill=\"rgba(10,10,16,.95)\" stroke=\"#7D7DDD\" stroke-opacity=\".8\" stroke-width=\"1\"/><text x=\"76\" y=\"144\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"600\" font-size=\"8.5\" letter-spacing=\"1\" fill=\"#fff\">MOXFINANCE</text></g>\n          <text x=\"230\" y=\"444\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"600\" font-size=\"8.5\" letter-spacing=\"1.6\" fill=\"rgba(245,244,248,.75)\">ONE GOVERNED RECORD</text>\n          <text x=\"230\" y=\"460\" text-anchor=\"middle\" font-family=\"Jost\" font-size=\"7.5\" letter-spacing=\"1.1\" fill=\"rgba(245,244,248,.6)\">VERIFIED ONCE · ENRICHED EVERYWHERE · VISIBLE TO EVERY PRODUCT</text>\n        </svg>\n      </div>\n    </div>\n  </div>\n</section>","<section class=\"chapter\" id=\"suite\" style=\"--acc:#FFDD00\">\n  <div class=\"frame chapter-body\">\n    <div style=\"max-width:940px\">\n      <div class=\"eyebrow rv\"><b>The Product Suite</b> Composable by Design</div>\n      <h2 class=\"display-lg rv rv-d1\">Six AI products.<br><span class=\"accent\">One platform.</span></h2>\n      <p class=\"lede rv rv-d2\" style=\"margin-top:26px\">Every product stands on its own. Together they compound — because they share the same data foundation and the same AI core by construction. MoxWarm and MoxCheck ship inside the MoxSend package.</p>\n    </div>\n    <div class=\"prod-grid\">\n      <div class=\"prod rv\" style=\"--pacc:#FFDD00\">\n        <span class=\"live on\"><i></i>LIVE</span>\n        <div class=\"mono\">MS</div>\n        <h3>MoxSend</h3>\n        <div class=\"ptag\">AI Outreach Engine</div>\n        <p class=\"pdesc\">AI cold outreach built on send-time and reply-time intelligence — the platform learns when every prospect opens and replies, then writes and times each email to land inside that window.</p>\n        <ul><li>Send-time &amp; reply-time intelligence</li><li>Culturally written Arabic cold emails</li><li>Multi-tenant from day one · MoxWarm + MoxCheck included</li></ul>\n        <a class=\"explore\" data-product=\"MoxSend\" href=\"https://moxsend.ai\">Explore MoxSend <span class=\"ar\">→</span></a>\n      </div>\n      <div class=\"prod rv\" style=\"--pacc:#FF810F\">\n        <span class=\"live on\"><i></i>LIVE</span>\n        <div class=\"mono\">MW</div>\n        <h3>MoxWarm</h3>\n        <div class=\"ptag\">AI Deliverability Engine <span class=\"bundle\">In the MoxSend package</span></div>\n        <p class=\"pdesc\">AI-orchestrated domain warm-up. Reputation ramp curves are computed and adjusted by AI daily — so sender trust is earned before a single campaign fires.</p>\n        <ul><li>AI-computed reputation ramp curves</li><li>Intelligent mailbox network simulation</li><li>Predictive deliverability telemetry</li></ul>\n        <a class=\"explore\" data-product=\"MoxWarm\" href=\"https://moxsend.ai\">Explore MoxWarm <span class=\"ar\">→</span></a>\n      </div>\n      <div class=\"prod rv\" style=\"--pacc:#7D7DDD\">\n        <span class=\"live on\"><i></i>LIVE</span>\n        <div class=\"mono\">MC</div>\n        <h3>MoxCheck</h3>\n        <div class=\"ptag\">AI Verification Engine <span class=\"bundle\">In the MoxSend package</span></div>\n        <p class=\"pdesc\">AI-assisted email verification that risk-scores every address in real time — syntax, MX, catch-all and trap detection before anything is sent.</p>\n        <ul><li>Real-time & bulk AI risk scoring</li><li>Catch-all and spam-trap detection</li><li>Zero-bounce hygiene, pre-send</li></ul>\n        <a class=\"explore\" data-product=\"MoxCheck\" href=\"https://moxsend.ai\">Explore MoxCheck <span class=\"ar\">→</span></a>\n      </div>\n      <div class=\"prod rv\" style=\"--pacc:#FFDD00\">\n        <span class=\"live soon\">IN BUILD</span>\n        <div class=\"mono\">CR</div>\n        <h3>MoxCRM</h3>\n        <div class=\"ptag\">AI Revenue Platform</div>\n        <p class=\"pdesc\">The AI revenue backbone of the platform — every reply, lead and deal flows into one AI-scored pipeline with next-best-action guidance for every rep.</p>\n        <ul><li>AI deal scoring & revenue forecasting</li><li>Reply → Lead → Deal automation</li><li>Native to the shared data foundation</li></ul>\n        <a class=\"explore\" data-product=\"MoxCRM\" href=\"#\">Explore MoxCRM <span class=\"ar\">→</span></a>\n      </div>\n      <div class=\"prod rv\" style=\"--pacc:#FF810F\">\n        <span class=\"live soon\">IN BUILD</span>\n        <div class=\"mono\">MQ</div>\n        <h3>MoxQuote</h3>\n        <div class=\"ptag\">AI Quoting Engine</div>\n        <p class=\"pdesc\">AI-drafted proposals with scope and cost woven into the narrative. Deal-DNA — the built-in AI model — predicts win probability before you hit send.</p>\n        <ul><li>AI-drafted narrative proposals</li><li>Industry preset architecture</li><li>Deal-DNA AI win prediction</li></ul>\n        <a class=\"explore\" data-product=\"MoxQuote\" href=\"#\">Explore MoxQuote <span class=\"ar\">→</span></a>\n      </div>\n      <div class=\"prod rv\" style=\"--pacc:#7D7DDD\">\n        <span class=\"live soon\">IN BUILD</span>\n        <div class=\"mono\">MF</div>\n        <h3>MoxFinance</h3>\n        <div class=\"ptag\">AI Books & Forecasting</div>\n        <p class=\"pdesc\">Your Books. Looking Forward. AI classifies every transaction, accelerates the close, and projects forward — with swappable Jurisdiction Packs for any market.</p>\n        <ul><li>AI transaction classification & close</li><li>Jurisdiction Packs · VAT & ZATCA-ready</li><li>AI forecasts fed by live platform data</li></ul>\n        <a class=\"explore\" data-product=\"MoxFinance\" href=\"#\">Explore MoxFinance <span class=\"ar\">→</span></a>\n      </div>\n    </div>\n  </div>\n</section>","<section class=\"chapter\" id=\"platforms\" style=\"--acc:#7D7DDD\">\n  <div class=\"frame chapter-body\">\n    <div style=\"max-width:940px\">\n      <div class=\"eyebrow rv\"><b>Industry Platforms</b> Vertical Depth</div>\n      <h2 class=\"display-lg rv rv-d1\">Purpose-built platforms.<br><span class=\"accent\">Entire industries each.</span></h2>\n      <p class=\"lede rv rv-d2\" style=\"margin-top:26px\">Beyond the horizontal suite, two flagship platforms carry the same AI-native architecture deep into their industries — complete operating systems, not add-on modules.</p>\n    </div>\n\n    <div class=\"plat rv\" style=\"--pacc:#FFDD00;margin-top:56px\">\n      <span class=\"wm\">Campus</span>\n      <div>\n        <div class=\"pl-kicker\">Education Platform</div>\n        <h3>MoxCampus</h3>\n        <div class=\"btag\">The AI Operating System for Independent Schools</div>\n        <p>Admissions to alumni, fees to timetables — one platform runs the entire institution. Predictive AI flags at-risk students before it becomes attrition, chases pending fees automatically, and turns the principal's morning into decisions instead of data entry. Multi-tenant from day one for school groups.</p>\n        <div class=\"pl-stats\">\n          <div><b>End-to-End</b><span>Admissions → Alumni</span></div>\n          <div><b>Predictive AI</b><span>Early-warning signals</span></div>\n          <div><b>Multi-Tenant</b><span>Group &amp; multi-campus ready</span></div>\n        </div>\n        <a class=\"explore\" data-product=\"MoxCampus\" href=\"#\" style=\"--pacc:#FFDD00;margin-top:30px;align-self:flex-start;padding:14px 30px\">Explore MoxCampus <span class=\"ar\">→</span></a>\n      </div>\n      <div class=\"plat