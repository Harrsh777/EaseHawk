       <text x=\"48\" y=\"150\" fill=\"rgba(245,244,248,.85)\">PARENT QUERIES ANSWERED &#8212; AI</text>\n          </g>\n          <g transform=\"rotate(-90 262 104)\">\n            <circle cx=\"262\" cy=\"104\" r=\"34\" fill=\"none\" stroke=\"rgba(255,255,255,.1)\" stroke-width=\"9\"/>\n            <circle cx=\"262\" cy=\"104\" r=\"34\" fill=\"none\" stroke=\"url(#cpG)\" stroke-width=\"9\" stroke-linecap=\"round\" stroke-dasharray=\"213.6\" stroke-dashoffset=\"213.6\">\n              <animate attributeName=\"stroke-dashoffset\" values=\"213.6;42;42;213.6\" keyTimes=\"0;.45;.85;1\" dur=\"6s\" repeatCount=\"indefinite\"/></circle>\n          </g>\n          <text x=\"262\" y=\"101\" text-anchor=\"middle\" font-family=\"Jost\" font-weight=\"700\" font-size=\"9\" fill=\"#fff\">FEES</text>\n          <text x=\"262\" y=\"113\" text-anchor=\"middle\" font-family=\"Jost\" font-size=\"6.4\" letter-spacing=\".8\" fill=\"rgba(245,244,248,.7)\">COLLECTED</text>\n          <text x=\"262\" y=\"152\" text-anchor=\"middle\" font-family=\"Jost\" font-size=\"6.8\" letter-spacing=\"1\" fill=\"rgba(245,244,248,.65)\">AI CHASES THE REST</text>\n          <g font-family=\"Jost\" font-size=\"6.8\" letter-spacing=\".8\" fill=\"rgba(245,244,248,.75)\">\n            <rect x=\"28\" y=\"170\" width=\"200\" height=\"9\" rx=\"4.5\" fill=\"rgba(255,221,0,.5)\"/><text x=\"236\" y=\"177.5\">ENQUIRIES</text>\n            <rect x=\"28\" y=\"186\" width=\"140\" height=\"9\" rx=\"4.5\" fill=\"rgba(255,168,20,.55)\"/><text x=\"176\" y=\"193.5\">CAMPUS TOURS</text>\n            <rect x=\"28\" y=\"202\" width=\"84\" height=\"9\" rx=\"4.5\" fill=\"url(#cpG)\"/><text x=\"120\" y=\"209.5\">ENROLLED</text>\n            <circle cy=\"174.5\" r=\"3\" fill=\"#FFDD00\"><animate attributeName=\"cx\" values=\"30;226;30\" dur=\"3.8s\" repeatCount=\"indefinite\"/></circle>\n            <text x=\"28\" y=\"224\" font-size=\"6.6\" fill=\"rgba(245,244,248,.6)\">ADMISSIONS PIPELINE &#8212; SCORED BY AI</text>\n          </g>\n          <text x=\"170\" y=\"256\" text-anchor=\"middle\" font-family=\"Jost\" font-size=\"7\" letter-spacing=\"1\" fill=\"rgba(245,244,248,.62)\">WHAT A PRINCIPAL SEES AT 8 AM &#8212; DECISIONS, NOT DATA ENTRY</text>\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"plat rv\" style=\"--pacc:#FF810F\">\n      <span class=\"wm\">Rev</span>\n      <div>\n        <div class=\"pl-kicker\">Automotive Platform</div>\n        <h3>MoxRev</h3>\n        <div class=\"btag\">The AI Operating System for Dealerships &amp; Rental Fleets</div>\n        <p>Sell. Rent. Rev it up. One platform runs both sides of the lot — showroom sales and rental operations — with AI dynamic pricing, utilisation intelligence and multi-entity operations engineered for Gulf-scale automotive groups.</p>\n        <div class=\"pl-stats\">\n          <div><b>Dual Engine</b><span>Sales + Rentals</span></div>\n          <div><b>AI Pricing</b><span>Dynamic &amp; demand-aware</span></div>\n          <div><b>Multi-Entity</b><span>Group-scale operations</span></div>\n        </div>\n        <a class=\"explore\" data-product=\"MoxRev\" href=\"#\" style=\"--pacc:#FF810F;margin-top:30px;align-self:flex-start;padding:14px 30px\">Explore MoxRev <span class=\"ar\">→</span></a>\n      </div>\n      <div class=\"plat-visual\">\n        <svg viewBox=\"0 0 340 270\" aria-hidden=\"true\">\n          <defs><linearGradient id=\"rvG\" x1=\"0\" x2=\"1\"><stop offset=\"0\" stop-color=\"#FF810F\"/><stop offset=\"1\" stop-color=\"#FFDD00\"/></linearGradient></defs>\n          <rect x=\"12\" y=\"14\" width=\"316\" height=\"220\" rx=\"12\" fill=\"rgba(10,10,16,.8)\" stroke=\"rgba(255,255,255,.14)\"/>\n          <text x=\"28\" y=\"40\" font-family=\"Jost\" font-weight=\"700\" font-size=\"9.5\" letter-spacing=\"1.5\" fill=\"#fff\">MOXREV &#183; OWNER&#8217;S COMMAND</text>\n          <circle cx=\"312\" cy=\"36\" r=\"4\" fill=\"#FF810F\"><animate attributeName=\"opacity\" values=\"1;.2;1\" dur=\"1.3s\" repeatCount=\"indefinite\"/></circle>\n          <text x=\"28\" y=\"60\" font-family=\"Jost\" font-size=\"7.4\" letter-spacing=\"1.2\" fill=\"rgba(245,244,248,.75)\">FLEET &#8212; EARNING VS IDLE</text>\n          <g>\n            <rect x=\"28\" y=\"68\" width=\"30\" height=\"14\" rx=\"4\" fill=\"url(#rvG)\"/>\n            <rect x=\"66\" y=\"68\" width=\"30\" height=\"14\" rx=\"4\" fill=\"url(#rvG)\"/>\n            <rect x=\"104\" y=\"68\" width=\"30\" height=\"14\" rx=\"4\" fill=\"url(#rvG)\"/>\n            <rect x=\"142\" y=\"68\" width=\"30\" height=\"14\" rx=\"4\" fill=\"url(#rvG)\"/>\n            <rect x=\"180\" y=\"68\" width=\"30\" height=\"14\" rx=\"4\" fill=\"url(#rvG)\"/>\n            <rect x=\"218\" y=\"68\" width=\"30\" height=\"14\" rx=\"4\" fill=\"url(#rvG)\" opacity=\".25\">\n              <animate attributeName=\"opacity\" values=\".25;1;1;.25\" keyTimes=\"0;.3;.8;1\" dur=\"5s\" repeatCount=\"indefinite\"/></rect>\n            <rect x=\"256\" y=\"68\" width=\"30\" height=\"14\" rx=\"4\" fill=\"rgba(255,255,255,.1)\"/>\n            <rect x=\"294\" y=\"68\" width=\"22\" height=\"14\" rx=\"4\" fill=\"rgba(255,255,255,.1)\"/>\n          </g>\n          <text x=\"28\" y=\"97\" font-family=\"Jost\" font-size=\"6.6\" letter-spacing=\".9\" fill=\"rgba(255,217,179,.8)\">AI JUST PUT ONE MORE CAR TO WORK</text>\n          <path d=\"M52 178 A 44 44 0 0 1 140 178\" fill=\"none\" stroke=\"rgba(255,255,255,.12)\" stroke-width=\"9\" stroke-linecap=\"round\"/>\n          <path d=\"M52 178 A 44 44 0 0 1 140 178\" fill=\"none\" stroke=\"url(#rvG)\" stroke-width=\"9\" stroke-linecap=\"round\" stroke-dasharray=\"138.2\" stroke-dashoffset=\"138.2\">\n            <animate attributeName=\"stroke-dashoffset\" values=\"138.2;30;30;138.2\" keyTimes=\"0;.45;.85;1\" dur=\"5.4s\" repeatCount=\"indefinite\"/></path>\n          <line x1=\"96\" y1=\"178\" x2=\"132\" y2=\"146\" stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\">\n            <animateTransform attributeName=\"transform\